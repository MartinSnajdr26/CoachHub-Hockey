# ----------------------------------------------------------------------------
# CoachHub Hockey — environment configuration example
# Copy to ".env" and fill in real values. NEVER commit your real .env.
# ----------------------------------------------------------------------------

# Application environment: dev | production
# In production (anything other than dev/development/local) the app FAILS TO BOOT
# unless SECRET_KEY and ADMIN_SECRET_KEY are set to strong values.
APP_ENV=dev

# Flask secret key — signs session cookies (team_id, team_role, owner_admin).
# REQUIRED in production. Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change_me_in_production

# Owner admin secret — gate for the /owner admin area.
# REQUIRED in production. In development a temporary value is auto-generated and
# printed to the console if this is unset.
ADMIN_SECRET_KEY=change_me_owner_admin_key

# Database URL. SQLite example (relative paths are resolved to absolute against
# the repo root). For PythonAnywhere use an absolute path, e.g.:
#   DB_URL=sqlite:////home/<youruser>/coachhub/data/prod.db
DB_URL=sqlite:///coach/dev.db

# Legal text versioning (used for consent prompts)
TERMS_VERSION=v1.0

# --- Optional ---
# DEBUG=0                         # set to 1 to force dev behavior (do NOT use in production)
# SESSION_LIFETIME_DAYS=30        # persistent team session length (1..365)
# REQUIRE_EMAIL_CONFIRMATION=1    # legacy flag; team-key login does not use e-mail
# OWNER_ACCESS_KEY=               # legacy owner key; NOT accepted as the production owner key

# Note: This app uses team key login (no SMTP / e-mail required).
# Note: Flask-Limiter uses in-memory storage by default (fine for a single
#       PythonAnywhere web worker). For multi-process, configure a Redis backend.
